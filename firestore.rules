rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for UserProgress
    function isValidUserProgress(data) {
      return data.keys().hasAll(['cards', 'customCodes'])
        && data.keys().size() <= 4 // cards, customCodes, lastUpdated, maybe uid
        && data.cards is map
        && data.customCodes is list
        && data.customCodes.size() <= 100;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProgress(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserProgress(request.resource.data)
        && (
          // Allow full updates for now as it's a single document state sync
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['cards', 'customCodes', 'lastUpdated'])
        );
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
